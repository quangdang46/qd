{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "QD Platforms Config",
  "description": "Schema for platforms.yaml - path to platform mapping",
  "type": "object",
  "properties": {
    "paths": {
      "type": "object",
      "description": "Map of relative paths to platform restrictions",
      "additionalProperties": {
        "type": "object",
        "properties": {
          "platforms": {
            "anyOf": [
              {
                "type": "array",
                "items": { "type": "string" },
                "description": "List of platform codes that can access this path"
              },
              {
                "type": "object",
                "properties": {
                  "supported": {
                    "type": "array",
                    "items": { "type": "string" }
                  }
                },
                "required": ["supported"]
              },
              {
                "type": "object",
                "properties": {
                  "unsupported": {
                    "type": "array",
                    "items": { "type": "string" }
                  }
                },
                "required": ["unsupported"]
              }
            ]
          }
        },
        "required": ["platforms"]
      }
    }
  }
}
