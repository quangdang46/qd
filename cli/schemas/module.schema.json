{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "QD Module Config",
  "description": "Schema for module.yaml",
  "type": "object",
  "required": ["code", "name"],
  "properties": {
    "code": {
      "type": "string",
      "description": "Module code identifier"
    },
    "name": {
      "type": "string",
      "description": "Module display name"
    },
    "description": {
      "type": "string",
      "description": "Module description"
    },
    "default_selected": {
      "type": "boolean",
      "description": "Whether this module is selected by default"
    },
    "module_version": {
      "type": "string",
      "description": "Module version"
    },
    "module_greeting": {
      "type": "string",
      "description": "Greeting message when module is activated"
    },
    "directories": {
      "type": "array",
      "items": { "type": "string" },
      "description": "Directories to create during installation"
    }
  }
}
